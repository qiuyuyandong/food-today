/* 主页面样式 */

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 2rpx 2rpx 8rpx rgba(0,0,0,0.2);
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.card-title-icon {
  margin-right: 12rpx;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.location-info.success {
  background: #e8f5e9;
  color: #2e7d32;
}

.location-info.error {
  background: #ffebee;
  color: #c62828;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 48rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-secondary {
  background: #f0f0f0;
  color: #333333;
}

.btn:disabled {
  opacity: 0.6;
}

/* 筛选组 */
.filter-group {
  margin-bottom: 32rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.range-value {
  color: #667eea;
  font-weight: 600;
}

.price-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.price-option {
  padding: 16rpx 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #ffffff;
}

.price-option.selected {
  background: #667eea;
  border-color: #667eea;
  color: #ffffff;
}

/* 标签页 */
.section-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eeeeee;
}

.section-tab {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.section-tab.active {
  background: #667eea;
  color: #ffffff;
}

.badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background: #ff5722;
  color: #ffffff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-count {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.count {
  color: #667eea;
  font-weight: 600;
}

/* 餐厅列表 */
.restaurant-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.restaurant-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.restaurant-item:last-child {
  border-bottom: none;
}

.restaurant-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.restaurant-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.restaurant-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.restaurant-rating {
  background: #ff9800;
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.restaurant-actions {
  display: flex;
  align-items: center;
}

.fav-btn {
  padding: 12rpx;
  font-size: 36rpx;
}

.fav-btn.active {
  color: #e91e63;
}

.restaurant-address {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666666;
  flex-wrap: wrap;
}

.nav-btn-inline {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #667eea;
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.menu-scroll {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  padding: 8rpx 0;
}

.menu-tag {
  flex-shrink: 0;
  background: #f0f0f0;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
}

.menu-tag.featured {
  background: #e3f2fd;
  color: #1976d2;
}

/* 历史记录 */
.history-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.history-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.history-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.history-rating {
  background: #ff9800;
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.history-detail {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.history-selection {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
}

/* 抽签卡片 */
.lottery-card {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.lottery-display {
  background: #ffffff;
  border: 4rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 24rpx 0;
  min-height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lottery-rolling {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  animation: pulse 0.3s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.lottery-result {
  text-align: center;
}

.result-shop-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.result-shop-info {
  font-size: 26rpx;
  color: #666666;
}

.lottery-placeholder {
  font-size: 32rpx;
  color: #999999;
}

.lottery-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.lottery-actions .btn {
  flex: 1;
  min-width: 240rpx;
}

/* 菜品选择卡片 */
.dish-card {
  background: #ffffff;
}

.selected-shop-info {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.shop-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.shop-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

/* 菜品标签页 */
.dish-tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.dish-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.dish-tab.active {
  background: #ffffff;
  color: #667eea;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #4caf50;
  color: #ffffff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-content {
  display: none;
}

.dish-content.active {
  display: block;
}

/* 菜品列表 */
.dish-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.dish-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.dish-item.selected {
  background: #667eea;
  border-color: #667eea;
  color: #ffffff;
}

.dish-item .dish-price {
  color: #e91e63;
  font-weight: 600;
}

.dish-item.selected .dish-price {
  color: #ffeb3b;
}

.dish-item .dish-badge {
  color: #ff9800;
  font-size: 22rpx;
}

/* 菜品抽取区域 */
.dish-draw-section {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.draw-title {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.draw-display {
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drawing-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  animation: pulse 0.3s ease-in-out infinite;
}

.drawn-result {
  text-align: center;
}

.result-dish-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.result-dish-price {
  display: block;
  font-size: 28rpx;
  color: #e91e63;
}

.draw-placeholder {
  font-size: 28rpx;
  color: #999999;
}

/* 完成区域 */
.finish-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx dashed #e0e0e0;
}

.selection-summary {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.summary-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.summary-item {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin: 12rpx 0;
}

.summary-total {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #e91e63;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #e0e0e0;
}

.finish-buttons {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.finish-buttons .btn {
  flex: 1;
  min-width: 280rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #eeeeee;
  position: sticky;
  top: 0;
  background: #ffffff;
  z-index: 10;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  padding: 8rpx;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

/* 详情区域 */
.detail-section {
  margin-bottom: 32rpx;
}

.detail-label {
  display: block;
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 12rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.rating-badge {
  display: inline-block;
  background: #ff9800;
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.price-tag {
  display: inline-block;
  color: #e91e63;
  font-weight: 600;
}

.address-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  background: #667eea;
  color: #ffffff;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 推荐列表 */
.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recommend-item {
  background: #e3f2fd;
  color: #1976d2;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.drink-list .recommend-item {
  background: #f3e5f5;
  color: #7b1fa2;
}

/* 总结弹窗 */
.summary-content {
  padding: 48rpx 32rpx;
}

.summary-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.summary-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.summary-body {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.summary-shop {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.shop-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.shop-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.summary-dish {
  display: flex;
  align-items: center;
  margin: 16rpx 0;
  font-size: 28rpx;
}

.dish-label {
  color: #666666;
  margin-right: 16rpx;
}

.dish-name {
  flex: 1;
  color: #333333;
  font-weight: 500;
}

.dish-price {
  color: #e91e63;
  font-weight: 600;
}

.summary-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 4rpx solid #667eea;
}

.total-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.total-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #e91e63;
}

.summary-actions {
  display: flex;
  gap: 20rpx;
}

.summary-actions .btn {
  flex: 1;
}

.share-btn {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.3);
}

/* Toast */
.toast {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%) translateY(200rpx);
  background: #333333;
  color: #ffffff;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  z-index: 2000;
  opacity: 0;
  transition: all 0.3s ease;
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.toast.success {
  background: #4caf50;
}

.toast.error {
  background: #f44336;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
